        "    if \"label\" in res.columns:\n",
        "        print(res[\"label\"].value_counts())\n",
        "    return res"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 7,
      "id": "14fc087d",
      "metadata": {},
      "outputs": [],
      "source": [
        "def downsample_label(df: pd.DataFrame, label: str, frac: float) -> pd.DataFrame:\n",
        "    label_df = df[df[\"label\"] == label]\n",
        "    df_other = df[df[\"label\"] != label]\n",
        "    label_df = label_df.sample(frac=frac, random_state=42)\n",
        "    combined_df = pd.concat([label_df, df_other])\n",
        "    print(combined_df[\"label\"].value_counts())\n",
        "    return combined_df"
      ]
    },
